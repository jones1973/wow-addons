<!-- shared/core/files.xml -->
<!-- Load order:
       theme system loads first (via Include). utils and any addon-side
       themeConfig depend on Addon.theme being available, so theme has
       to come before the rest of the foundation.
       Foundation modules (events, dependencies, svRegistry, errorHandler,
       stateMachine) have no inter-dependencies; order matches PAO's
       core/files.xml convention.
       Services (utils, pool, location, options, commands, tabs,
       dataStore, tooltipUtils) build on the foundation. Subdir
       manifests (exports/, etc.) auto-Include at the end via sync.sh.
-->
<Ui>
    <Include file="theme\files.xml"/>

    <Script file="events.lua"/>
    <Script file="dependencies.lua"/>
    <Script file="svRegistry.lua"/>
    <Script file="errorHandler.lua"/>
    <Script file="stateMachine.lua"/>

    <Script file="utils.lua"/>
    <Script file="pool.lua"/>
    <Script file="location.lua"/>
    <Script file="options.lua"/>
    <Script file="commands.lua"/>
    <Script file="tabs.lua"/>
    <Script file="dataStore.lua"/>
    <Script file="tooltipUtils.lua"/>
</Ui>
